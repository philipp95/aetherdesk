# Django
ENVIRONMENT=local
DEBUG=True
SECRET_KEY=change-me-for-local-development
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
TIME_ZONE=UTC

# Database
# Local default if unset: sqlite:///db.sqlite3
# Production/staging: use Neon pooled or direct PostgreSQL connection string.
DATABASE_URL=sqlite:///db.sqlite3

# Security / HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# Cloudflare R2 media storage
USE_CLOUDFLARE_R2=False
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_CUSTOM_DOMAIN=cdn.aetherdesk.com
R2_MEDIA_LOCATION=media
R2_QUERYSTRING_AUTH=False

# Email / Postmark SMTP-ready defaults
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.postmarkapp.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Aetherdesk <noreply@aetherdesk.com>

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=False
